---
import DocsLayout from '@/layouts/DocsLayout.astro'
import { Button } from '@/components/starwind/button'
import { Card, CardHeader, CardTitle, CardDescription } from '@/components/starwind/card'
import { Badge } from '@/components/starwind/badge'

const ecosystem = [
  {
    title: 'Aurelia Language',
    description: 'Systems programming language with first-class tensor primitives.',
    icon: 'code',
    href: '/essentials/aurelia-language',
    color: 'from-indigo-500 to-purple-500'
  },
  {
    title: 'Zenith Kernel',
    description: 'Microkernel with probabilistic scheduling and AI-Watchdog.',
    icon: 'cpu',
    href: '/essentials/zenith-kernel',
    color: 'from-purple-500 to-pink-500'
  },
  {
    title: 'SkyOS',
    description: 'Generative OS powered by Large Action Models.',
    icon: 'monitor',
    href: '/essentials/skyos',
    color: 'from-pink-500 to-rose-500'
  },
  {
    title: 'DeepComet Models',
    description: '10B+ parameter models for kernel optimization.',
    icon: 'brain',
    href: '/ai/deepcomet-models',
    color: 'from-rose-500 to-orange-500'
  },
  {
    title: 'SkyCloud',
    description: 'Decentralized cloud network sharing idle NPU power.',
    icon: 'cloud',
    href: '/ai/skycloud',
    color: 'from-orange-500 to-amber-500'
  },
  {
    title: 'The Forge',
    description: 'Automated migration of legacy codebases into Aurelia.',
    icon: 'hammer',
    href: '/ai/the-forge',
    color: 'from-amber-500 to-yellow-500'
  }
]

const features = [
  {
    title: 'Vertical Integration',
    description: "AI isn't bolted on—it's the core. From language to kernel to OS.",
    icon: 'sparkles'
  },
  {
    title: 'First-Class Tensors',
    description: 'Native tensor primitives with automatic differentiation built-in.',
    icon: 'box'
  },
  {
    title: 'Direct NPU Targeting',
    description: 'Bypass CPU bottlenecks with MLIR compilation to NPU.',
    icon: 'cpu'
  }
]
---

<DocsLayout title="Deepcomet AI Documentation">
  <!-- Hero Section -->
  <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-indigo-500/10 via-purple-500/10 to-pink-500/10 border border-border p-8 md:p-12 mb-12">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 via-purple-500/5 to-pink-500/5"></div>
    <div class="relative">
      <Badge variant="secondary" class="mb-4">
        Documentation
      </Badge>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
        <span class="bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent">
          Deepcomet AI
        </span>
      </h1>
      <p class="text-xl text-muted-foreground max-w-2xl mb-8">
        Build the future of AI. Explore the technical foundations of the Deepcomet AI ecosystem.
      </p>
      <div class="flex flex-wrap gap-4">
        <Button href="/getting-started/index/" size="lg" class="gap-2">
          Get Started
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </Button>
        <Button href="https://github.com/Nehal-aditya" target="_blank" variant="outline" size="lg" class="gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </Button>
      </div>
    </div>
  </div>

  <!-- Ecosystem Grid -->
  <div class="mb-16">
    <h2 class="text-2xl font-bold mb-6">The Ecosystem</h2>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {ecosystem.map((item) => (
        <a
          href={item.href}
          class="group block p-6 rounded-xl border border-border bg-card hover:border-primary/50 hover:bg-muted/50 transition-all duration-300 hover:-translate-y-1"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class={`p-2.5 rounded-lg bg-gradient-to-br ${item.color} text-white shadow-lg`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
            </div>
            <h3 class="font-bold text-foreground group-hover:text-primary transition-colors">{item.title}</h3>
          </div>
          <p class="text-sm text-muted-foreground group-hover:text-foreground transition-colors">
            {item.description}
          </p>
        </a>
      ))}
    </div>
  </div>

  <!-- Features Section -->
  <div class="mb-16">
    <h2 class="text-2xl font-bold mb-6">Key Features</h2>
    <div class="grid gap-8 md:grid-cols-3">
      {features.map((feature) => (
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-gradient-to-br from-indigo-500/20 to-purple-500/20 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275Z"/></svg>
          </div>
          <h3 class="font-bold text-foreground mb-2">{feature.title}</h3>
          <p class="text-sm text-muted-foreground">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- CTA Section -->
  <div class="text-center p-8 rounded-2xl bg-gradient-to-br from-muted/50 to-muted border border-border">
    <h2 class="text-2xl font-bold mb-2">Ready to build with Deepcomet?</h2>
    <p class="text-muted-foreground mb-6">Start exploring the documentation and build the future of AI today.</p>
    <div class="flex flex-wrap justify-center gap-4">
      <Button href="/getting-started/index/" size="lg">
        Start Learning
      </Button>
      <Button href="/essentials/aurelia-language" variant="outline" size="lg">
        Explore Ecosystem
      </Button>
    </div>
  </div>
</DocsLayout>
