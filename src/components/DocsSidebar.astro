---
import type { DocCategory } from '@/lib/content'

interface Props {
  categories: DocCategory[]
  currentPath: string
}

const { categories, currentPath } = Astro.props

const sectionIcons: Record<string, string> = {
  'getting-started': '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
  'essentials': '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  'ai': '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="m16.2 7.8 2.9-2.9"/><path d="M18 12h4"/><path d="m16.2 16.2 2.9 2.9"/><path d="M12 18v4"/><path d="m4.9 19.1 2.9-2.9"/><path d="M2 12h4"/><path d="m4.9 4.9 2.9 2.9"/></svg>'
}
---

<!-- Mobile Overlay -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden transition-opacity opacity-0"></div>

<!-- Sidebar -->
<aside
  id="docs-sidebar"
  class="fixed left-0 top-16 bottom-0 w-72 bg-sidebar-background border-r border-sidebar-border z-40 overflow-y-auto transition-transform duration-300 ease-out -translate-x-full lg:translate-x-0"
>
  <div class="p-4 space-y-6">
    <!-- Home Link -->
    <a
      href="/"
      class:list={[
        "flex items-center gap-2.5 px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200",
        currentPath === '/' 
          ? 'bg-primary/10 text-primary' 
          : 'text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground'
      ]}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Home
    </a>

    <!-- Divider -->
    <div class="h-px bg-sidebar-border"></div>

    <!-- Navigation Sections -->
    <div class="space-y-1">
      <p class="px-3 text-[10px] font-semibold text-sidebar-foreground/50 uppercase tracking-wider">Documentation</p>
      
      {categories.map((category) => {
        const hasActivePage = category.pages.some(page => {
          const pagePath = `/${category.slug}/${page.slug}`
          return currentPath === pagePath || currentPath.startsWith(pagePath + '/')
        })
        
        return (
          <div class="space-y-0.5">
            <button
              class="flex items-center w-full gap-2.5 px-3 py-2 text-xs font-semibold text-sidebar-foreground/60 uppercase tracking-wider hover:text-sidebar-foreground transition-colors sidebar-section-toggle group"
              data-section={category.slug}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 sidebar-chevron text-sidebar-foreground/40 group-hover:text-sidebar-foreground" data-section={category.slug}><polyline points="9 18 15 12 9 6"/></svg>
              <span class="flex items-center gap-2">
                {category.name}
              </span>
            </button>

            <div class="space-y-0.5 ml-5 sidebar-section-content" data-section={category.slug}>
              {category.pages.map((page) => {
                const pagePath = `/${category.slug}/${page.slug}`
                const isActive = currentPath === pagePath || currentPath.startsWith(pagePath + '/')
                return (
                  <a
                    href={pagePath}
                    class:list={[
                      "block px-3 py-1.5 text-sm rounded-md transition-all duration-200 border-l-[1.5px]",
                      isActive
                        ? 'bg-primary/8 text-primary border-l-primary font-medium'
                        : 'text-sidebar-foreground/70 hover:text-sidebar-foreground hover:bg-sidebar-accent/50 border-l-transparent'
                    ]}
                  >
                    {page.title}
                  </a>
                )
              })}
            </div>
          </div>
        )
      })}
    </div>
  </div>
</aside>

<script>
  // Handle sidebar section toggles
  const toggles = document.querySelectorAll('.sidebar-section-toggle')
  toggles.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const section = toggle.getAttribute('data-section')
      const content = document.querySelector(`.sidebar-section-content[data-section="${section}"]`)
      const chevron = document.querySelector(`.sidebar-chevron[data-section="${section}"]`)
      
      if (content && chevron) {
        content.classList.toggle('hidden')
        chevron.classList.toggle('rotate-90')
      }
    })
  })

  // Auto-expand active sections
  const path = window.location.pathname
  document.querySelectorAll('.sidebar-section-content').forEach(content => {
    const links = content.querySelectorAll('a')
    const isActive = Array.from(links).some(link => {
      const href = link.getAttribute('href')
      return href && (path === href || path.startsWith(href + '/'))
    })
    
    if (isActive) {
      content.classList.remove('hidden')
      const section = content.getAttribute('data-section')
      const chevron = document.querySelector(`.sidebar-chevron[data-section="${section}"]`)
      if (chevron) chevron.classList.add('rotate-90')
    } else {
      content.classList.add('hidden')
    }
  })

  // Mobile sidebar
  const sidebarToggle = document.getElementById('sidebar-toggle')
  const sidebar = document.getElementById('docs-sidebar')
  const overlay = document.getElementById('sidebar-overlay')

  if (sidebarToggle && sidebar && overlay) {
    sidebarToggle.addEventListener('click', () => {
      sidebar.classList.toggle('-translate-x-full')
      overlay.classList.toggle('hidden')
      overlay.classList.toggle('opacity-0')
    })

    overlay.addEventListener('click', () => {
      sidebar.classList.add('-translate-x-full')
      overlay.classList.add('hidden')
      overlay.classList.add('opacity-0')
    })
  }
</script>
