---
import { Button } from '@/components/starwind/button'
import { Input } from '@/components/starwind/input'
import ThemeToggle from '@/components/starwind/theme-toggle/ThemeToggle.astro'
---

<header class="fixed top-0 left-0 right-0 z-50 h-16 border-b border-border/50 bg-background/60 backdrop-blur-2xl">
  <div class="h-full max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between">
    <!-- Left -->
    <div class="flex items-center gap-4">
      <button 
        id="sidebar-toggle"
        class="lg:hidden inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:text-foreground hover:bg-muted transition-colors"
        aria-label="Toggle sidebar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>

      <a href="/" class="flex items-center gap-3 group">
        <div class="relative w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 via-violet-500 to-fuchsia-500 flex items-center justify-center shadow-lg shadow-indigo-500/25 group-hover:shadow-indigo-500/40 transition-all duration-300">
          <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-indigo-400/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275Z"/>
          </svg>
        </div>
        <div class="hidden sm:flex flex-col">
          <span class="font-bold text-base tracking-tight leading-none">
            Deepcomet
          </span>
          <span class="text-[10px] text-muted-foreground tracking-wider uppercase font-medium">Docs</span>
        </div>
      </a>
    </div>

    <!-- Center - Search -->
    <div class="hidden md:flex flex-1 max-w-lg mx-8">
      <button 
        id="search-trigger"
        class="group w-full flex items-center gap-3 px-4 py-2.5 rounded-full bg-muted/40 border border-border/40 text-muted-foreground hover:bg-muted/80 hover:border-border/60 hover:text-foreground transition-all duration-300 text-sm shadow-sm hover:shadow-md"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60 group-hover:opacity-100 transition-opacity"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <span class="flex-1 text-left font-medium">Search documentation...</span>
        <kbd class="px-2 py-0.5 text-[10px] bg-background/80 border border-border/50 rounded-full text-muted-foreground font-mono">⌘K</kbd>
      </button>
    </div>

    <!-- Right -->
    <div class="flex items-center gap-1">
      <ThemeToggle />

      <a
        href="https://github.com/Nehal-aditya"
        target="_blank"
        class="inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:text-foreground hover:bg-muted transition-colors"
        aria-label="GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
    </div>
  </div>
</header>

<!-- Search Dialog -->
<div id="search-dialog" class="fixed inset-0 z-[100] hidden">
  <div class="absolute inset-0 bg-black/70 backdrop-blur-md transition-opacity opacity-0" id="search-overlay"></div>
  <div class="relative z-10 mx-auto mt-[12vh] max-w-2xl px-4">
    <div class="rounded-2xl bg-popover border border-border/60 shadow-2xl shadow-black/50 overflow-hidden ring-1 ring-white/10">
      <div class="p-4 border-b border-border/50">
        <div class="relative flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input 
            type="text"
            id="search-input"
            placeholder="Search documentation..." 
            class="flex-1 pl-12 pr-12 py-4 bg-transparent text-foreground placeholder:text-muted-foreground/70 focus:outline-none text-lg font-medium"
            autocomplete="off"
          />
          <button id="search-close" class="absolute right-3 top-1/2 -translate-y-1/2 p-2 rounded-full text-muted-foreground hover:text-foreground hover:bg-muted/80 transition-all" aria-label="Close search">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
      </div>
      <div id="search-results" class="max-h-[50vh] overflow-y-auto p-2">
        <div class="text-center py-8 text-muted-foreground text-sm">
          Type to search...
        </div>
      </div>
      <div class="px-4 py-3 border-t border-border bg-muted/30 text-xs text-muted-foreground flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="flex items-center gap-1"><kbd class="px-1.5 py-0.5 bg-background border border-border rounded">↑</kbd> <kbd class="px-1.5 py-0.5 bg-background border border-border rounded">↓</kbd> Navigate</span>
          <span class="flex items-center gap-1"><kbd class="px-1.5 py-0.5 bg-background border border-border rounded">↵</kbd> Select</span>
        </div>
        <span class="flex items-center gap-1"><kbd class="px-1.5 py-0.5 bg-background border border-border rounded">Esc</kbd> Close</span>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const searchDialog = document.getElementById('search-dialog')
  const searchOverlay = document.getElementById('search-overlay')
  const searchTrigger = document.getElementById('search-trigger')
  const searchInput = document.getElementById('search-input')
  const searchResults = document.getElementById('search-results')

  let pages = []
  let selectedIndex = -1
  let indexLoaded = false

  async function loadSearchIndex() {
    if (indexLoaded) return
    try {
      const response = await fetch('/search-index.json')
      if (response.ok) {
        pages = await response.json()
        indexLoaded = true
      }
    } catch (e) {
      // Fallback to sidebar links
      const links = document.querySelectorAll('aside a[href^="/"]')
      pages = Array.from(links).map(link => ({
        title: link.textContent.trim(),
        path: link.getAttribute('href'),
        description: '',
        content: ''
      })).filter(p => p.title && p.path && p.path !== '/')
    }
  }

  function openSearch() {
    searchDialog.classList.remove('hidden')
    document.body.style.overflow = 'hidden'
    searchOverlay.classList.remove('opacity-0')
    loadSearchIndex().then(() => {
      setTimeout(() => searchInput.focus(), 50)
    })
  }

  function closeSearch() {
    searchDialog.classList.add('hidden')
    searchOverlay.classList.add('opacity-0')
    document.body.style.overflow = ''
    searchInput.value = ''
    selectedIndex = -1
  }

  function highlightMatch(text, query) {
    const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi')
    return text.replace(regex, '<mark class="bg-primary/20 text-primary px-0.5 rounded">$1</mark>')
  }

  function getSnippet(content, query, maxLength = 120) {
    const lowerContent = content.toLowerCase()
    const lowerQuery = query.toLowerCase()
    const index = lowerContent.indexOf(lowerQuery)
    if (index === -1) return content.slice(0, maxLength) + '...'
    
    const start = Math.max(0, index - 40)
    const end = Math.min(content.length, index + query.length + 40)
    const snippet = (start > 0 ? '...' : '') + content.slice(start, end) + (end < content.length ? '...' : '')
    return snippet
  }

  function renderResults(query) {
    if (!query) {
      searchResults.innerHTML = '<div class="text-center py-8 text-muted-foreground text-sm">Type to search...</div>'
      return
    }

    const lowerQuery = query.toLowerCase()
    const filtered = pages.filter(p => 
      p.title.toLowerCase().includes(lowerQuery) ||
      (p.description && p.description.toLowerCase().includes(lowerQuery)) ||
      (p.content && p.content.toLowerCase().includes(lowerQuery)) ||
      p.path.toLowerCase().includes(lowerQuery)
    )

    if (filtered.length === 0) {
      searchResults.innerHTML = `<div class="text-center py-8 text-muted-foreground text-sm">No results for "${query}"</div>`
      return
    }

    searchResults.innerHTML = filtered.slice(0, 8).map((page, index) => {
      const title = highlightMatch(page.title, query)
      const category = page.category || page.path.split('/')[1] || ''
      const snippet = page.content ? getSnippet(page.content, query) : (page.description || '')
      const highlightedSnippet = highlightMatch(snippet, query)
      
      return `
      <a href="${page.path}" 
         class="search-result block px-4 py-3 rounded-xl transition-all duration-200 ${index === selectedIndex ? 'bg-primary/10 text-primary' : 'text-foreground hover:bg-muted/80'}"
         data-index="${index}"
      >
        <div class="flex items-center gap-2 mb-1">
          <span class="text-[10px] uppercase tracking-wider text-muted-foreground font-medium">${category}</span>
        </div>
        <div class="font-semibold text-sm mb-1">${title}</div>
        ${snippet ? `<div class="text-xs text-muted-foreground line-clamp-2 leading-relaxed">${highlightedSnippet}</div>` : ''}
      </a>
    `}).join('')
  }

  function updateSelection(results) {
    results.forEach((el, i) => {
      if (i === selectedIndex) {
        el.classList.add('bg-primary/10', 'text-primary')
        el.classList.remove('text-foreground', 'hover:bg-muted/80')
        el.scrollIntoView({ block: 'nearest' })
      } else {
        el.classList.remove('bg-primary/10', 'text-primary')
        el.classList.add('text-foreground', 'hover:bg-muted/80')
      }
    })
  }

  if (searchTrigger) searchTrigger.addEventListener('click', openSearch)
  if (searchOverlay) searchOverlay.addEventListener('click', closeSearch)
  const searchCloseBtn = document.getElementById('search-close')
  if (searchCloseBtn) searchCloseBtn.addEventListener('click', closeSearch)

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      selectedIndex = -1
      renderResults(e.target.value)
    })

    searchInput.addEventListener('keydown', (e) => {
      const results = document.querySelectorAll('.search-result')
      
      if (e.key === 'ArrowDown') {
        e.preventDefault()
        selectedIndex = Math.min(selectedIndex + 1, results.length - 1)
        updateSelection(results)
      } else if (e.key === 'ArrowUp') {
        e.preventDefault()
        selectedIndex = Math.max(selectedIndex - 1, 0)
        updateSelection(results)
      } else if (e.key === 'Enter') {
        e.preventDefault()
        const idx = selectedIndex >= 0 ? selectedIndex : 0
        if (results[idx]) window.location.href = results[idx].getAttribute('href')
      } else if (e.key === 'Escape') {
        closeSearch()
      }
    })
  }

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault()
      openSearch()
    }
    if (e.key === 'Escape' && !searchDialog.classList.contains('hidden')) {
      closeSearch()
    }
  })
})()
</script>
